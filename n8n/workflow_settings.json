    {
      "id": "s03",
      "name": "Code: Format Settings",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 300],
      "parameters": {
        "jsCode": "const items = $input.all();\nconst settings = {};\nitems.forEach(item => {\n  const key = item.json.key || '';\n  const val = item.json.value || '';\n  if (key) settings[key.trim()] = String(val).trim();\n});\nreturn [{ json: { settings } }];"
      }
    },

    {
      "id": "s04",
      "name": "Respond GET Settings",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [900, 300],
      "parameters": {
        "respondWith": "json",
        "options": {
          "responseHeaders": {
            "entries": [
              { "name": "Access-Control-Allow-Origin", "value": "*" },
              { "name": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
              { "name": "Access-Control-Allow-Headers", "value": "Content-Type" }
            ]
          }
        }
      }
    },

    {
      "id": "s05",
