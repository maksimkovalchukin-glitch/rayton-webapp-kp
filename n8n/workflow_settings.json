    {
      "id": "s06",
      "name": "Code: Prepare Settings Rows",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 600],
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst settings = input.body?.settings || input.settings || {};\n\nconst values = Object.entries(settings).map(([k, v]) => [k, String(v)]);\n\nconst SHEET_ID = '1IgaI0_eE0xY7ljfNh138CA-aYIiFzGJpmu9s2hLV04g';\nconst SHEET_ENC = encodeURIComponent('Налаштування');\n\nconst clearUrl = `https://sheets.googleapis.com/v4/spreadsheets/${SHEET_ID}/values/${SHEET_ENC}!A2:B200:clear`;\nconst writeUrl = `https://sheets.googleapis.com/v4/spreadsheets/${SHEET_ID}/values/${SHEET_ENC}!A2:B?valueInputOption=RAW`;\nconst writeBody = JSON.stringify({\n  range: 'Налаштування!A2:B',\n  majorDimension: 'ROWS',\n  values: values.length ? values : [['', '']]\n});\n\nreturn [{ json: { settings, clearUrl, writeUrl, writeBody } }];"
      }
    },

